# =============================================
# Frog.ai — Environment Setup
# =============================================
#
# SETUP INSTRUCTIONS (do this on every new computer):
#
#  1. Copy this file and rename it to:  .env.local
#  2. Get a free Groq API key at:       https://console.groq.com/keys
#  3. Paste your key below
#  4. Run:  npm install && npm run dev
#
# =============================================

# Your Groq API key (required)
GROQ_API_KEY=gsk_your_key_here

# Model (optional — default is already set in code)
GROQ_MODEL=llama-3.1-8b-instant
