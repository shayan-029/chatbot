# =============================================
# Turtle.ai — Environment Setup
# =============================================
#
# SETUP INSTRUCTIONS (do this on every new computer):
#
#  1. Copy this file and rename it to:  .env.local
#  2. Fill in your Groq API key and MongoDB URI below
#  3. Run:  npm install && npm run dev
#
# =============================================

# Your Groq API key (required) — get one free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Model (optional — default is already set in code)
GROQ_MODEL=llama-3.1-8b-instant

# MongoDB Atlas connection string (required for chat history)
# Get it from: cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/turtle_ai?retryWrites=true&w=majority&authSource=admin
